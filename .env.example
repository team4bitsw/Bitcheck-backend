# ============================================================
# Bitcheck / ProofChain AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# ============================================================

# Django
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — PostgreSQL
DB_NAME=bitcheck
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS — Next.js frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Bitcheck Token Economy
BITCHECK_NAIRA_PER_BIT=100

# Google OAuth
GOOGLE_CLIENT_ID=

# Squad Payment Gateway
SQUAD_SECRET_KEY=
SQUAD_WEBHOOK_SECRET=
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com

# ML / FastAPI Service
ML_SERVICE_BASE_URL=http://localhost:8001

# Object Storage (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=bitcheck-uploads
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1

# API Key Pepper
API_KEY_PEPPER=
