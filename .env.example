# ============================================================
# Bitcheck / ProofChain AI — Environment Variables Template
# Copy this file to .env and fill in your values.
# ============================================================

# Django
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Dev server: default is `python manage.py runserver` → http://127.0.0.1:8000/
# If port 8000 is busy on your machine, use another port and point the Next.js
# `NEXT_PUBLIC_API_URL` in your (gitignored) frontend `.env.local` at the same origin, e.g. http://localhost:8001/

# Logging — structured JSON lines on stdout from `bitcheck` logger (see apps/core/logger.py)
# APP_LOG_LEVEL=DEBUG|INFO|WARNING|ERROR  (optional; defaults from Django DEBUG)
# APP_LOG_HTTP_BODIES=1   — log truncated request/response body previews (off in prod unless set)
# APP_LOG_RESPONSE_BODY=1 — when bodies on, also log successful responses (default: errors + 4xx still get response preview when bodies on)
# APP_LOG_MAX_BODY=4096   — max chars per body preview

# Database — Django reads DATABASE_URL via dj-database-url (see config/settings.py).
# Neon: use the pooled connection string from the Neon dashboard; include sslmode=require.
# Example shape (use your real user/password/host — do not commit secrets):
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# If the pooler misbehaves with your client, try appending channel_binding=require or use the
# non-pooled host from Neon’s connection details.
#
# Leave unset or empty to fall back to SQLite (db.sqlite3) for quick local-only dev.
DATABASE_URL=

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS — Next.js frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Bitcheck Token Economy
BITCHECK_NAIRA_PER_BIT=100

# Google OAuth
GOOGLE_CLIENT_ID=

# Squad Payment Gateway
# Use the SECRET key from sandbox.squadco.com (Get Started) — format sandbox_sk_…
# Do not use the public / publishable key in Authorization.
# B2B endpoint POST /virtual-account/business returns 403 until Squad profiles your merchant;
# contact their support if you need sandbox access.
# Mock VA (no Squad call): set SQUAD_VA_DEV_MOCK=True — loaded from Bitcheck-backend/.env via BASE_DIR
# (not cwd). Restart Django after changing. Never enable in production.
SQUAD_SECRET_KEY=
SQUAD_WEBHOOK_SECRET=
SQUAD_BASE_URL=https://sandbox-api-d.squadco.com
SQUAD_VA_DEV_MOCK=False

# ML / FastAPI Service
ML_SERVICE_BASE_URL=http://localhost:8001

# Connectors (Gmail, Slack, …) — credential encryption + public webhook base URL
# Generate a Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONNECTOR_CREDENTIALS_KEY=
CONNECTORS_PUBLIC_BASE_URL=http://localhost:8000
# Optional; defaults to Django SECRET_KEY when unset (dev only).
CONNECTORS_OAUTH_STATE_SECRET=
CONNECTORS_DEFAULT_RATE_LIMIT_PER_INSTALL=60
CONNECTORS_DEFAULT_RATE_LIMIT_PER_TYPE=1000
# Optional — Rate limits use Redis when set; otherwise LocMem (single-process).
REDIS_CACHE_URL=

# Telegram — shared @Bot for consumer linking (PR1+). Optional until you enable Telegram.
TELEGRAM_SHARED_BOT_TOKEN=
# Same value passed to setWebhook(secret_token); required for webhook verification in production.
TELEGRAM_SHARED_BOT_SECRET=
# Bot username without @ (used in t.me deep links)
TELEGRAM_SHARED_BOT_USERNAME=BitcheckBot
# Consumer app origin (verification links in Telegram replies)
FRONTEND_APP_BASE_URL=http://localhost:3000

# Google OAuth — Gmail connector (same client can be used for login if configured in GCP)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match an authorized redirect URI in Google Cloud Console (trailing slash as below).
# Local: match your runserver port. Prod: your Cloud Run API host only (not Vercel).
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/api/connectors/oauth/gmail/callback/

# Object Storage (S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=bitcheck-uploads
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=us-east-1

# API Key Pepper
API_KEY_PEPPER=
